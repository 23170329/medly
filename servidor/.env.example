# ── Entorno ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Base de datos (Azure Database for PostgreSQL) ──────────────────
# En Azure App Service, configura DATABASE_URL en Variables de Entorno
# del Portal con el connection string de tu Azure PostgreSQL Flexible Server.
# Como alternativa, usa variables separadas:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medly
DB_USER=postgres
DB_PASS=secret

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=genera_un_secreto_seguro_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=genera_otro_secreto_aqui
JWT_REFRESH_EXPIRES_IN=7d

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_XXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXX

# ── URLs ──────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8081
APP_PUBLIC_URL=http://localhost:3000

# ── Depuración (solo desarrollo) ─────────────────────────────────
# LOGIN_DEBUG=true  → en consola del API verás si falló por correo inexistente o por contraseña
