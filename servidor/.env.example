# ── Entorno ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Base de datos (Railway PostgreSQL) ────────────────────────────
# Railway asigna DATABASE_URL automáticamente al crear la DB.
# Si no, usa variables separadas:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medly
DB_USER=postgres
DB_PASS=secret

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=genera_un_secreto_seguro_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=genera_otro_secreto_aqui
JWT_REFRESH_EXPIRES_IN=7d

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_XXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXX

# ── URLs ──────────────────────────────────────────────────────────
# En Railway, la URL del frontend (Expo)
FRONTEND_URL=http://localhost:8081
# URL pública del API para redirects de Stripe
APP_PUBLIC_URL=http://localhost:3000
