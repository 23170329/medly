# ── Modo Railway (recomendado) ───────────────────────────────────
# Copia este archivo a .env en la raíz y en servidor/.
# Las variables sensibles (JWT_SECRET, DATA_ENCRYPTION_KEY, Stripe)
# deben configurarse en el dashboard de Railway, NO en .env.
#
# Railway asigna DATABASE_URL automáticamente al crear PostgreSQL.

DATABASE_URL=postgresql://USER:PASS@HOST:PORT/railway

APP_PUBLIC_URL=https://tu-api.up.railway.app
EXPO_PUBLIC_API_URL=https://tu-api.up.railway.app
FRONTEND_URL=http://localhost:8081
PORT=3000

JWT_SECRET=igual_que_en_railway_variables
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=igual_que_en_railway_variables
JWT_REFRESH_EXPIRES_IN=7d

STRIPE_SECRET_KEY=sk_test_XXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXX
EXPO_PUBLIC_STRIPE_PK=pk_test_XXXX

# Cifrado AES-256-GCM (consultas clínicas). Generar:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Obligatorio en Railway: agregar en Variables del servicio API.
DATA_ENCRYPTION_KEY=105fad38fb29db9b938eac99ce8212fb8a0581c236d8fdd9934107f1c56a4185

# ── Modo local (Docker + API en tu PC) ───────────────────────────
# Descomenta y ajusta estas líneas para desarrollo local.
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=medly
# DB_USER=postgres
# DB_PASS=secret
# EXPO_PUBLIC_API_URL=http://192.168.X.X:3000
# APP_PUBLIC_URL=http://192.168.X.X:3000
