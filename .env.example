# ── Modo Railway (recomendado) ───────────────────────────────────
# Copia a .env en la raíz y en servidor/; en cliente/ solo las EXPO_PUBLIC_*.

DATABASE_URL=postgresql://USER:PASS@HOST:PORT/railway

APP_PUBLIC_URL=https://tu-api.up.railway.app
EXPO_PUBLIC_API_URL=https://tu-api.up.railway.app
FRONTEND_URL=http://localhost:8081
PORT=3000

JWT_SECRET=igual_que_en_railway_variables
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=igual_que_en_railway_variables
JWT_REFRESH_EXPIRES_IN=7d

STRIPE_SECRET_KEY=sk_test_XXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXX
EXPO_PUBLIC_STRIPE_PK=pk_test_XXXX

# ── Modo local (Docker + API en tu PC) ───────────────────────────
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=medly
# DB_USER=postgres
# DB_PASS=secret
# EXPO_PUBLIC_API_URL=http://192.168.X.X:3000
# APP_PUBLIC_URL=http://192.168.X.X:3000
