# Copia este archivo a .env en cada subcarpeta y rellena los valores

# ── Compartido ───────────────────────────────────────────────────
NODE_ENV=development

# ── Base de datos ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medly
DB_USER=postgres
DB_PASS=secret

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_en_produccion
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=cambia_esto_refresh
JWT_REFRESH_EXPIRES_IN=7d

# ── Stripe ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_XXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXX
EXPO_PUBLIC_STRIPE_PK=pk_test_XXXX

# ── URLs ─────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://192.168.X.X:3000
FRONTEND_URL=http://localhost:8081
PORT=3000
